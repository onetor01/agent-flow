{
  "name": "agent-flow",
  "license": "MIT",
  "displayName": "agent-flow",
  "description": "可视化地编排 Agent 工作流",
  "version": "0.0.64",
  "publisher": "FanetheDivine",
  "repository": {
    "type": "git",
    "url": "https://github.com/FanetheDivine/agent-flow.git"
  },
  "icon": "resources/icon.png",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-flow-sidebar",
          "title": "Agent Flow",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "agent-flow-sidebar": [
        {
          "id": "agent-flow.runChanges",
          "name": "文件变更",
          "contextualTitle": "Agent Flow",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "agent-flow.openPanel",
        "title": "Open Agent Flow",
        "icon": "resources/icon.svg"
      },
      {
        "command": "agent-flow.addSelectionToInput",
        "title": "Agent Flow: Add Selection to Active Input"
      },
      {
        "command": "agent-flow.openRunFile",
        "title": "Agent Flow: Open File"
      },
      {
        "command": "agent-flow.openRunDiffFile",
        "title": "Agent Flow: Open Diff"
      }
    ],
    "keybindings": [
      {
        "command": "agent-flow.addSelectionToInput",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "agent-flow.openPanel",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.mjs",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.mjs --watch",
    "watch:tsc": "tsc --build --watch",
    "package": "npm run check-types && npm run lint && node esbuild.mjs --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --build",
    "format": "prettier --write src/",
    "lint": "eslint src",
    "test": "vscode-test",
    "build-extension": "npx @vscode/vsce package --no-dependencies",
    "release": "node scripts/update-preset-flows.mjs && node scripts/release.mjs"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^2.1.2",
    "@ant-design/icons": "^6.1.1",
    "@ant-design/x": "^2.5.0",
    "@ant-design/x-markdown": "^2.5.0",
    "@anthropic-ai/claude-agent-sdk": "^0.3.156",
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@dagrejs/dagre": "^3.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-virtual": "^3.13.25",
    "@xyflow/react": "^12.10.2",
    "ahooks": "^3.9.7",
    "antd": "^6.3.5",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "execa": "^9.6.1",
    "immer": "^11.1.4",
    "lodash-es": "^4.18.1",
    "mermaid": "^11.15.0",
    "motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^6.1.1",
    "react-virtuoso": "^4.18.7",
    "slate": "^0.124.1",
    "slate-history": "^0.113.1",
    "slate-react": "^0.124.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "ts-pattern": "^5.9.0",
    "use-immer": "^0.11.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@vscode/vsce-sign",
      "esbuild",
      "keytar"
    ],
    "supportedArchitectures": {
      "os": [
        "win32",
        "darwin",
        "linux"
      ],
      "cpu": [
        "x64",
        "arm64"
      ],
      "libc": [
        "glibc",
        "musl"
      ]
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/lodash-es": "^4.17.12",
    "@types/mocha": "^10.0.10",
    "@types/node": "~22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.115.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.27.3",
    "esbuild-plugin-tailwindcss": "^2.2.0",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.9",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
